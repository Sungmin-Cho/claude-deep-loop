{
  "$schema": "deep-loop/v0.4.0",
  "required": ["schema_version","run_id","goal","status","project","routing","review","autonomy","budget","comprehension","circuit_breaker","session_chain","workstreams","active_workstreams","triage","episodes","termination","project.binding_generation","autonomy.continuation_policy","autonomy.attended_launch_approval","session_chain.lease.takeover_kind"],
  "enums": {
    "status": ["running","paused","completed","stopped"],
    "routing.protocol": ["deep-work","superpowers","standalone"],
    "autonomy.tier": ["read-only","recommend","act-reversible","act-gated"],
    "autonomy.spawn_style": ["visible","interactive","headless","desktop"],
    "autonomy.continuation_policy": ["workstream-session","compact-in-place","rotate-per-unit"],
    "budget.unit": ["turns","tokens"],
    "session_chain.lease.state": ["active","releasing","released"],
    "session_chain.lease.handoff_phase": ["idle","reserved","emitted","spawned","acquired"],
    "session_spawn.launcher": ["cmux","iterm2","terminal-app","wt","powershell","tmux","none"],
    "autonomy.session_effort": ["low","medium","high","xhigh","max"],
    "autonomy.session_runtime": ["claude","codex"],
    "autonomy.runtime_source": ["skill-asserted"]
  },
  "properties": {
    "session_spawn": { "type": "object" },
    "pause_reason": { "type": "string" },
    "session_chain.lease.resume_policy": { "type": "string" },
    "session_chain.lease.handoff_trigger": { "type": ["string", "null"] },
    "session_chain.lease.takeover_kind": { "type": ["string", "null"] },
    "session_chain.consumed_milestones": { "type": "array" },
    "autonomy.session_model": { "type": "string" },
    "autonomy.session_runtime": { "type": "string" },
    "autonomy.runtime_source": { "type": "string" },
    "autonomy.runtime_executable_approval": { "type": ["object", "null"] },
    "autonomy.launcher_executable_approvals": { "type": "object" },
    "autonomy.attended_launch_approval": { "type": ["object", "null"] },
    "project.binding_generation": { "type": "integer", "minimum": 1 },
    "episodes[].request_rel": { "type": "string" },
    "session_chain.sessions[].handoff_rel": { "type": "string" },
    "session_chain.sessions[].scope": { "type": "object" }
  },
  "episode_status": { "skill": ["pending","in_progress","blocked"], "kernel": ["done","approved","rejected","abandoned"] },
  "workstream_status": { "skill": ["planned","in_progress","in_review","parked"], "kernel": ["ready","merged","abandoned"] }
}
